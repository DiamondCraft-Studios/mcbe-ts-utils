{
	"compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
		"rootDir": "src",
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"strict": true,
		"removeComments": true,
		"noImplicitAny": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"noEmitHelpers": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
